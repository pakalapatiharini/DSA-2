import java.util.*;

public class DFSCycleDetection {

    static final int WHITE = 0;
    static final int GREY = 1;
    static final int BLACK = 2;

    static Map<String, List<String>> graph = new HashMap<>();
    static Map<String, Integer> color = new HashMap<>();

    static boolean dfs(String node) {
        color.put(node, GREY);
        System.out.println("Visit " + node + " (GREY)");

        for (String neighbor : graph.getOrDefault(node, new ArrayList<>())) {

            if (color.get(neighbor) == GREY) {
                System.out.println("\nCYCLE DETECTED!");
                System.out.println("Back Edge Found: "
                        + node + " -> " + neighbor);
                return true;
            }

            if (color.get(neighbor) == WHITE) {
                if (dfs(neighbor))
                    return true;
            }
        }

        color.put(node, BLACK);
        System.out.println("Finish " + node + " (BLACK)");
        return false;
    }

    public static void main(String[] args) {

        // Graph:
        // deploy -> build
        // build -> test
        // test -> integration
        // integration -> build

        graph.put("deploy", Arrays.asList("build"));
        graph.put("build", Arrays.asList("test"));
        graph.put("test", Arrays.asList("integration"));
        graph.put("integration", Arrays.asList("build"));

        for (String node : graph.keySet()) {
            color.put(node, WHITE);
        }

        System.out.println("DFS CYCLE DETECTION");
        System.out.println("-------------------");

        boolean cycleFound = dfs("deploy");

        if (cycleFound) {
            System.out.println("\nCycle:");
            System.out.println("build -> test -> integration -> build");
            System.out.println("\nWorkflow Validation: CI Rejected");
        } else {
            System.out.println("\nNo Cycle Found");
            System.out.println("Workflow Validation: Accepted");
        }

        System.out.println("\nTime Complexity: O(V + E)");
    }
}
